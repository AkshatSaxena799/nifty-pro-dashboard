# Environment Variables
# Copy this file to .env and fill in any optional values.

# Backend port (default: 3001)
PORT=3001

# Frontend build API URL (leave empty for same-origin in production)
# Only needed if frontend and backend are on different domains.
VITE_API_URL=http://localhost:3001/api

# Optional: override data storage paths
# TRADING_DATA_DIR=./data
